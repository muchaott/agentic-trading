{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strategy-ledger.local/schemas/research_artifact.schema.json",
  "title": "Strategy Ledger Research Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "artifact_hash",
    "created_at",
    "publication_state",
    "instrument",
    "strategy_family",
    "strategy_variant",
    "strategy_rule_version",
    "methodology_version",
    "data_snapshot",
    "assumptions",
    "backtest_run",
    "metric_snapshot",
    "performance_series",
    "research_report",
    "disclosure",
    "content_review"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{4,120}$"
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "publication_state": {
      "type": "string",
      "enum": ["draft", "quant_reviewed", "compliance_reviewed", "published", "retired", "archived"]
    },
    "instrument": {
      "$ref": "#/$defs/instrument"
    },
    "strategy_family": {
      "$ref": "#/$defs/strategy_family"
    },
    "strategy_variant": {
      "$ref": "#/$defs/strategy_variant"
    },
    "strategy_rule_version": {
      "$ref": "#/$defs/strategy_rule_version"
    },
    "methodology_version": {
      "$ref": "#/$defs/methodology_version"
    },
    "data_snapshot": {
      "$ref": "#/$defs/data_snapshot"
    },
    "assumptions": {
      "$ref": "#/$defs/assumptions"
    },
    "backtest_run": {
      "$ref": "#/$defs/backtest_run"
    },
    "metric_snapshot": {
      "$ref": "#/$defs/metric_snapshot"
    },
    "performance_series": {
      "$ref": "#/$defs/performance_series"
    },
    "research_report": {
      "$ref": "#/$defs/research_report"
    },
    "disclosure": {
      "$ref": "#/$defs/disclosure"
    },
    "content_review": {
      "$ref": "#/$defs/content_review"
    }
  },
  "$defs": {
    "instrument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "name", "exchange", "asset_class", "category", "data_rights_status"],
      "properties": {
        "ticker": { "type": "string", "pattern": "^[A-Z][A-Z0-9.:-]{0,15}$" },
        "name": { "type": "string", "minLength": 1 },
        "exchange": { "type": "string", "minLength": 1 },
        "asset_class": { "type": "string", "enum": ["ETF", "ETN", "Index", "Equity", "Other"] },
        "category": { "type": "string", "minLength": 1 },
        "data_rights_status": {
          "type": "string",
          "enum": ["prototype_only", "internal_research", "display_approved", "redistribution_approved"]
        }
      }
    },
    "strategy_family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family_id", "name", "methodology_summary"],
      "properties": {
        "family_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$" },
        "name": { "type": "string", "minLength": 1 },
        "methodology_summary": { "type": "string", "minLength": 1 }
      }
    },
    "strategy_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id", "slug", "status", "risk_band", "approved_benchmarks"],
      "properties": {
        "variant_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{2,100}$" },
        "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,120}$" },
        "status": { "type": "string", "enum": ["research", "paper_live", "live_track_record", "retired"] },
        "risk_band": { "type": "string", "enum": ["Low", "Moderate", "Elevated", "High"] },
        "approved_benchmarks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9.:-]{0,15}$" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "strategy_rule_version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_version_id", "implementation_hash", "rule_text", "parameters"],
      "properties": {
        "rule_version_id": { "type": "string", "minLength": 1 },
        "implementation_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "rule_text": { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      }
    },
    "methodology_version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methodology_version_id", "summary", "known_limitations"],
      "properties": {
        "methodology_version_id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "known_limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    },
    "data_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "vendor", "as_of_date", "price_adjustment", "license_scope"],
      "properties": {
        "snapshot_id": { "type": "string", "minLength": 1 },
        "vendor": { "type": "string", "minLength": 1 },
        "as_of_date": { "type": "string", "format": "date" },
        "price_adjustment": { "type": "string", "enum": ["raw", "split_adjusted", "split_and_dividend_adjusted"] },
        "license_scope": { "type": "string", "enum": ["prototype_only", "internal_research", "display_approved", "redistribution_approved"] }
      }
    },
    "assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assumptions_version_id", "initial_capital", "commission_bps", "slippage_bps", "taxes_included", "execution_timing"],
      "properties": {
        "assumptions_version_id": { "type": "string", "minLength": 1 },
        "initial_capital": { "type": "number", "exclusiveMinimum": 0 },
        "commission_bps": { "type": "number", "minimum": 0 },
        "slippage_bps": { "type": "number", "minimum": 0 },
        "taxes_included": { "type": "boolean" },
        "execution_timing": { "type": "string", "minLength": 1 }
      }
    },
    "backtest_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "engine_version", "sample_start", "sample_end", "benchmark_ticker", "created_by"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "engine_version": { "type": "string", "minLength": 1 },
        "sample_start": { "type": "string", "format": "date" },
        "sample_end": { "type": "string", "format": "date" },
        "benchmark_ticker": { "type": "string", "pattern": "^[A-Z][A-Z0-9.:-]{0,15}$" },
        "created_by": { "type": "string", "minLength": 1 }
      }
    },
    "metric_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cagr",
        "total_return",
        "annualized_volatility",
        "max_drawdown",
        "benchmark_return",
        "excess_return",
        "turnover",
        "trade_count",
        "win_rate",
        "worst_month",
        "worst_year"
      ],
      "properties": {
        "cagr": { "type": "number" },
        "total_return": { "type": "number" },
        "annualized_volatility": { "type": "number", "minimum": 0 },
        "max_drawdown": { "type": "number", "maximum": 0 },
        "benchmark_return": { "type": "number" },
        "excess_return": { "type": "number" },
        "sharpe": { "type": ["number", "null"] },
        "sortino": { "type": ["number", "null"] },
        "turnover": { "type": "number", "minimum": 0 },
        "trade_count": { "type": "integer", "minimum": 0 },
        "win_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "worst_month": { "type": "number", "maximum": 0 },
        "worst_year": { "type": "number", "maximum": 0 }
      }
    },
    "performance_series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalized_equity", "benchmark_equity", "drawdown", "monthly_returns", "yearly_returns"],
      "properties": {
        "normalized_equity": { "$ref": "#/$defs/dated_number_series" },
        "benchmark_equity": { "$ref": "#/$defs/dated_number_series" },
        "drawdown": { "$ref": "#/$defs/dated_number_series" },
        "monthly_returns": { "$ref": "#/$defs/dated_number_series" },
        "yearly_returns": { "$ref": "#/$defs/dated_number_series" }
      }
    },
    "dated_number_series": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "value"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "value": { "type": "number" }
        }
      }
    },
    "research_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "limitations", "methodology_url"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "methodology_url": { "type": "string", "minLength": 1 }
      }
    },
    "disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disclosure_version_id", "performance_type", "no_advice_text", "no_guarantee_text", "conflict_disclosure"],
      "properties": {
        "disclosure_version_id": { "type": "string", "minLength": 1 },
        "performance_type": { "type": "string", "enum": ["hypothetical_backtest", "paper_live", "live_track_record"] },
        "no_advice_text": { "type": "string", "minLength": 1 },
        "no_guarantee_text": { "type": "string", "minLength": 1 },
        "conflict_disclosure": { "type": "string", "minLength": 1 }
      }
    },
    "content_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "quant_reviewer", "compliance_reviewer", "approved_at", "review_notes"],
      "properties": {
        "stage": { "type": "string", "enum": ["draft", "quant_reviewed", "compliance_reviewed", "published", "retired", "archived"] },
        "quant_reviewer": { "type": ["string", "null"] },
        "compliance_reviewer": { "type": ["string", "null"] },
        "approved_at": { "type": ["string", "null"], "format": "date-time" },
        "review_notes": { "type": "string" }
      }
    }
  }
}
